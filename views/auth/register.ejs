      <hr>
      <div class="form-row">
        <div class="form-group">
          <label>Skills (comma separated)</label>
          <input type="text" name="skills" placeholder="e.g. skill01, skill02, skill03">
        </div>
        <div class="form-group">
          <label>Hourly Rate ($)</label>
