<%# THE FOLLOWING PAGE'S FUNCTION:
Registration page for new users.
Controller passes { user }.
Handles both freelancer and client registration with role toggle. %>

<%- include('../partials/header', { title: 'Register' }) %>
<%- include('../partials/navbar') %>

<main>
  <h2>Create an Account</h2>
  <p>Join Next Hire and start your journey</p>

  <% if (typeof error !== 'undefined') { %>
    <p class="error"><%= error %></p>
  <% } %>

  <form action="/auth/register" method="POST">
    <input type="hidden" name="role" id="roleInput" value="freelancer">

    <%# GLASS ROLE TOGGLE %>
    <div class="role-cards">
      <div class="role-card selected" id="card-freelancer" onclick="selectRole('freelancer')">
        <h3>&#128188; Freelancer</h3>
      </div>
      <div class="role-card" id="card-client" onclick="selectRole('client')">
        <h3>&#127970; Client</h3>
      </div>
    </div>

    <%# SHARED FIELDS %>
    <label>Full Name *</label>
    <input type="text" name="name" placeholder="e.g. John Doe" required>

    <label>Email *</label>
    <input type="email" name="email" placeholder="e.g. john@email.com" required>

    <label>Password *</label>
    <input type="password" name="password" placeholder="Enter a strong password" required>

    <%# FREELANCER SPECIFIC FIELDS %>
